{
    "name": "Requirement-Analyzer",
    "version": "1.0.0",
    "description": "INCOSE Requirement Analyzer",
    "main": "dist/main/src/main/main.js",
    "scripts": {
        "build:backend": "tsc -p tsconfig.backend.json",
        "build:main": "tsc -p tsconfig.main.json",
        "build:renderer": "tsc -p tsconfig.renderer.json",
        "build": "npm run build:backend && npm run build:main && npm run build:renderer",
        "dev:backend": "tsx watch src/backend/server.ts",
        "dev:main": "electron .",
        "dev": "concurrently \"npm run dev:backend\" \"npm run dev:main\"",
        "start": "electron .",
        "dist": "npm run build && electron-builder"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "repository": {
        "type": "git",
        "url": "https://github.com/Hyuna-319/Codelia.git"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^4.17.21",
        "@types/node": "^20.10.6",
        "@types/wait-on": "^5.3.4",
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1",
        "ts-node": "^10.9.2",
        "tsx": "^4.7.0",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.12.0",
        "@google/generative-ai": "^0.1.3",
        "concurrently": "^8.2.2",
        "cors": "^2.8.5",
        "express": "^4.18.2",
        "openai": "^4.24.1",
        "wait-on": "^7.2.0"
    },
    "build": {
        "appId": "com.example.requirementimprover",
        "productName": "Requirement Analyzer",
        "publish": null,
        "mac": {
            "target": "dmg",
            "category": "public.app-category.productivity"
        },
        "win": {
            "target": "nsis",
            "icon": "build/icon.ico"
        },
        "files": [
            "dist/**/*",
            "index.html",
            "prompts/**/*",
            "!src/**",
            "!tsconfig*.json",
            "!**/*.ts",
            "!build_python.sh",
            "!requirements.txt",
            "!modules/**",
            "!config.py",
            "!api.py",
            "!.github/**",
            "!*.spec"
        ],
        "extraResources": [
            {
                "from": "prompts",
                "to": "prompts",
                "filter": [
                    "**/*"
                ]
            }
        ]
    }
}